{
  "expo": {
    "name": "Calmi",
    "slug": "calmi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Calmimind uses the camera to scan QR codes and barcodes."
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {}
  }
}
